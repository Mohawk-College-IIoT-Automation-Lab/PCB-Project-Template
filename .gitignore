# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/


# Adapted from: https://github.com/github/gitignore
# Changed to include to ignore production files

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived Backups (KiCad 6.0)
**/*-backups/*.zip

# Local project settings
*.kicad_prl

# Production files generetaed for JLCPCB
# Files are generated with the help of 
# JLC PCB plugin (https://github.com/Bouni/kicad-jlcpcb-tools)
# Stored in /jlcpcb directory
jlcpcb/*

# Release Files
*_Release/*